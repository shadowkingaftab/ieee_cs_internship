# Streamlit Secrets Template
# On Streamlit Community Cloud:
#   App Settings → Secrets → paste the content below (without the comments)
#
# Locally: copy to .streamlit/secrets.toml (it's gitignored)

[general]
GROK_API_KEY = "your-xai-api-key-here"

# Optional: quantization level (q2_k | q4_k_m | q8_0)
# QWEN_QUANT = "q4_k_m"
