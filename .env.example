# Edge AI Intent Classifier — Environment Variables
# Copy this to .env and fill in your values

# ── Grok API (Cloud LLM — Primary) ───────────────────────────────────────────
# Get your key at: https://console.x.ai
GROK_API_KEY=your-xai-key-here

# ── Qwen2-0.5B Quantization Level ─────────────────────────────────────────────
# q2_k   = 323MB — fastest, best for low-end hardware (Raspberry Pi, old laptops)
# q4_k_m = 379MB — balanced speed/quality (DEFAULT, recommended)
# q8_0   = 506MB — highest quality CPU inference
QWEN_QUANT=q4_k_m

# ── Qwen Hardware Tuning (auto-detected if not set) ───────────────────────────
# QWEN_THREADS=4      # CPU threads (auto = physical cores, max 8)
# QWEN_BATCH=256      # Batch size (auto from RAM: 128=<8GB, 256=8-16GB, 512=>16GB)
# QWEN_GPU_LAYERS=0   # GPU offload layers (0=CPU only, -1=full GPU)
# QWEN_CTX=2048       # Context window size

# ── Fine-tuned Classifier (optional) ─────────────────────────────────────────
# Set this after running: python training/train_classifier.py --eval
# CLASSIFIER_MODEL_PATH=models/fine_tuned_classifier
